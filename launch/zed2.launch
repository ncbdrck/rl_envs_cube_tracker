<launch>
  <!--
    rl_envs_cube_tracker: detect the cube tag with apriltag_ros on a
    zed2 image stream and republish on /cube_pose.

    Assumes the zed_wrapper / zed_ros_wrapper is publishing the rectified
    rgb stream under /zed2/zed_node/rgb/.
  -->

  <arg name="camera_ns"       default="/zed2/zed_node/rgb"/>
  <arg name="image_topic"     default="image_rect_color"/>

  <arg name="cube_tag_id"     default="0"/>
  <arg name="target_frame"    default=""/>
  <arg name="output_topic"    default="/cube_pose"/>
  <arg name="rate_limit_hz"   default="0.0"/>
  <arg name="node_namespace"  default="apriltag_ros_continuous_node"/>

  <rosparam command="load" file="$(find rl_envs_cube_tracker)/config/settings.yaml"
            ns="$(arg node_namespace)"/>
  <rosparam command="load" file="$(find rl_envs_cube_tracker)/config/tags.yaml"
            ns="$(arg node_namespace)"/>

  <node pkg="apriltag_ros" type="apriltag_ros_continuous_node"
        name="$(arg node_namespace)" clear_params="true" output="screen">
    <remap from="image_rect" to="$(arg camera_ns)/$(arg image_topic)"/>
    <remap from="camera_info" to="$(arg camera_ns)/camera_info"/>
    <param name="publish_tag_detections_image" type="bool" value="true"/>
  </node>

  <node pkg="rl_envs_cube_tracker" type="tag_to_cube_pose.py"
        name="tag_to_cube_pose" output="screen">
    <param name="cube_tag_id"   value="$(arg cube_tag_id)"/>
    <param name="target_frame"  value="$(arg target_frame)"/>
    <param name="rate_limit_hz" value="$(arg rate_limit_hz)"/>
    <remap from="~detections"   to="/tag_detections"/>
    <remap from="~cube_pose"    to="$(arg output_topic)"/>
  </node>
</launch>
