<launch>
  <!--
    rl_envs_cube_tracker: detect the cube tag with apriltag_ros on a
    kinect2 image stream and republish on /cube_pose for the real-side
    push / PnP envs.

    Assumes kinect2_bridge is already running and publishing under
    /kinect2 (the default base_name). qhd (960x540) is the right
    trade-off for tag detection — full HD is overkill at our range,
    sd is too low-res for reliable corners.
  -->

  <!-- Camera topic root (default kinect2_bridge layout). -->
  <arg name="camera_ns"       default="/kinect2/qhd"/>
  <arg name="image_topic"     default="image_color_rect"/>

  <!-- Cube tracking + output. -->
  <arg name="cube_tag_id"     default="0"/>
  <arg name="target_frame"    default=""/>   <!-- e.g. rx200/base_link to TF-transform -->
  <arg name="output_topic"    default="/cube_pose"/>
  <arg name="rate_limit_hz"   default="0.0"/>
  <arg name="node_namespace"  default="apriltag_ros_continuous_node"/>

  <!-- Camera extrinsic. Set publish_extrinsic_tf:=false if your URDF /
       robot_state_publisher already provides the camera_optical TF chain. -->
  <arg name="publish_extrinsic_tf" default="true"/>
  <arg name="extrinsic_file"  default="$(find rl_envs_cube_tracker)/config/extrinsics/kinect2_to_rx200.yaml"/>

  <!-- apriltag_ros detector (tag36h11, our tags.yaml + settings.yaml). -->
  <rosparam command="load" file="$(find rl_envs_cube_tracker)/config/settings.yaml"
            ns="$(arg node_namespace)"/>
  <rosparam command="load" file="$(find rl_envs_cube_tracker)/config/tags.yaml"
            ns="$(arg node_namespace)"/>

  <node pkg="apriltag_ros" type="apriltag_ros_continuous_node"
        name="$(arg node_namespace)" clear_params="true" output="screen">
    <remap from="image_rect" to="$(arg camera_ns)/$(arg image_topic)"/>
    <remap from="camera_info" to="$(arg camera_ns)/camera_info"/>
    <param name="publish_tag_detections_image" type="bool" value="true"/>
  </node>

  <!-- Adapter: tag_detections → /cube_pose -->
  <node pkg="rl_envs_cube_tracker" type="tag_to_cube_pose.py"
        name="tag_to_cube_pose" output="screen">
    <param name="cube_tag_id"   value="$(arg cube_tag_id)"/>
    <param name="target_frame"  value="$(arg target_frame)"/>
    <param name="rate_limit_hz" value="$(arg rate_limit_hz)"/>
    <remap from="~detections"   to="/tag_detections"/>
    <remap from="~cube_pose"    to="$(arg output_topic)"/>
  </node>

  <!-- Camera extrinsic TF: rx200/base_link → kinect2_rgb_optical_frame.
       Edit the YAML to match your mount; see config/extrinsics/README.md. -->
  <node if="$(arg publish_extrinsic_tf)"
        pkg="rl_envs_cube_tracker" type="publish_camera_tf.py"
        name="kinect2_extrinsic_tf" output="screen">
    <param name="extrinsic_file" value="$(arg extrinsic_file)"/>
  </node>
</launch>
